# 實機測試用環境變數
# 使用方式：
#   1. 複製這個檔案改名為 .env.device（同目錄）
#   2. 把 IP 改成你電腦在區域網路的 IP（cmd 輸入 ipconfig 查 IPv4 位址）
#   3. 手機和電腦必須連同一個 Wi-Fi
# .env.device 不會被 commit（已在 .gitignore）

VITE_API_BASE_URL=http://192.168.0.100:5000

# Google 登入用：Google Cloud Console 建立 OAuth「Web 應用程式」client 後，把 Web client ID 貼上。
# 沒填的話 Google 登入鈕會顯示「尚未設定」，其餘登入照常。
VITE_GOOGLE_WEB_CLIENT_ID=

# Facebook 登入用：Meta for Developers 建立 App 後，填入 App ID 與 Client Token（皆非機密）。
# App Secret 是機密，請放後端 User Secrets / env（Authentication__Facebook__AppSecret），不要放這裡。
# 沒填的話 Facebook 登入鈕會顯示「尚未設定」，其餘登入照常。
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_CLIENT_TOKEN=
